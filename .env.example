# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwXyZ

# Your personal chat ID — send /start to @userinfobot on Telegram to find it
TELEGRAM_CHAT_ID=987654321

# ── Discord (Sable's chat surface — replaces Telegram) ──────────────────────
# Bot token from the Discord Developer Portal (also used by discord_ingest.py).
# Enable the MESSAGE CONTENT intent for the bot.
DISCORD_BOT_TOKEN=
# Channel IDs (enable Developer Mode in Discord → right-click channel → Copy ID).
# #sable-broadcast: everything Sable initiates (alerts, digest, reminders, MMI).
DISCORD_BROADCAST_CHANNEL=
# #sable-chat: your space to start a conversation with Sable.
DISCORD_CHAT_CHANNEL=
# Webhook URL for #sable-broadcast (channel settings → Integrations → Webhooks).
# Used by out-of-process senders that can't share the bot's single gateway.
DISCORD_BROADCAST_WEBHOOK=
# Leading character for commands (e.g. "!analyze BBOX"). Default: !
COMMAND_PREFIX=!

# Optional: override the directory where stock .md files live (default: same folder as run.py)
# STOCKS_DIR=/path/to/your/stocks

# NOTE: NSE price data via yfinance has an ~15 minute delay (Yahoo Finance free tier).
# Alerts are based on delayed prices. This is unavoidable without a paid data feed.

# Screener.in login — used by fetch_fundamentals.py to extract promoter pledge %
# (pledge data requires a logged-in session; free account at screener.in)
SCREENER_EMAIL=you@example.com
SCREENER_PASSWORD=yourpassword

# CalDAV calendar server (Radicale) — subscribe over Tailscale
# Default port is 5232. Subscribe in Apple/Google Calendar via:
#   http://<tailscale-ip>:5232/algotrading-events/
# CALDAV_PORT=5232
# CALDAV_CALENDAR_NAME=algotrading-events

# ── Zerodha Kite Connect ────────────────────────────────────────────────────
# Omit all ZERODHA_* vars to run the bot in yfinance-only mode (no change to
# existing behavior). Get API_KEY + API_SECRET from https://kite.trade/
# TOTP_SECRET is the base32 seed Zerodha shows during 2FA setup — NOT the
# 6-digit rotating code. In your Kite Connect app settings, set redirect_url
# to any URL (e.g. http://127.0.0.1) — the server does not need to be live.
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_USER_ID=
ZERODHA_PASSWORD=
ZERODHA_TOTP_SECRET=

# Polling intervals (seconds) — defaults below; override only if needed
# POLL_INTERVAL_SECONDS=10           # used when Kite WebSocket is connected (default)
# POLL_INTERVAL_FALLBACK_SECONDS=180 # used when falling back to yfinance (default)

# ── Groww Trade API ─────────────────────────────────────────────────────────────
# Alternative to Zerodha. If both are set, Kite is used (unset ZERODHA_API_KEY
# to switch). TOTP_SECRET is the base32 seed from Groww's 2FA setup page.
# Get API_KEY from https://groww.in/trade-api/api-keys
GROWW_API_KEY=
GROWW_TOTP_SECRET=
